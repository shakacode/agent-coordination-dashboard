{
  "name": "agents-coordination-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Local dashboard for viewing agent coordination state and preparing pr-batch prompts.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shakacode/agent-coordination-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/shakacode/agent-coordination-dashboard/issues"
  },
  "homepage": "https://github.com/shakacode/agent-coordination-dashboard#readme",
  "scripts": {
    "demo": "node node_modules/tsx/dist/cli.mjs scripts/demo.ts",
    "dev": "node node_modules/tsx/dist/cli.mjs src/server/index.ts",
    "build": "node node_modules/typescript/bin/tsc --noEmit -p tsconfig.node.json && node node_modules/vite/bin/vite.js build",
    "preview": "NODE_ENV=production node node_modules/tsx/dist/cli.mjs src/server/index.ts",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit -p tsconfig.json && node node_modules/typescript/bin/tsc --noEmit -p tsconfig.node.json && node node_modules/typescript/bin/tsc --noEmit -p tsconfig.scripts.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "express": "^5.2.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.0",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
